pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/sachilz/dockerized-mern-app'
            }
        }

        stage('List Files') {
            steps {
                bat 'dir'
            }
        }

         stage('Gitleaks Secret Scan') {
            steps {
                bat 'detect --source . --verbose'
            }
        }
    }
}