pipeline {
    agent any

    environment {
        GITLEAKS_PATH = "C:\\DevSecOps\\gitleaks\\gitleaks.exe"
        SONAR_SCANNER = "C:\\DevSecOps\\sonar-scanner\\bin\\sonar-scanner.bat"
        TRIVY_PATH = "C:\\DevSecOps\\trivy\\trivy.exe"
    }

    stages {

        // 1. SOURCE CODE
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/sachilz/User-Management-App-with-Jenkins-DevSecOps-Pipeline.git'
            }
        }

        // 2. SECRET SCAN (EARLY - SHIFT LEFT SECURITY)
        stage('Gitleaks Secret Scan') {
            steps {
                bat "\"${GITLEAKS_PATH}\" detect --source . --verbose"
            }
        }

        // 3. INSTALL + BUILD VALIDATION
        stage('Build Validation') {
            steps {
                dir('backend') {
                    bat 'npm install'
                }

                dir('frontend') {
                    bat 'npm install'
                    bat 'npm run build'
                }
            }
        }

        // 4. SAST SCAN (SONARQUBE)
        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        bat """
                        \"${SONAR_SCANNER}\" ^
                        -Dsonar.projectKey=dockerized-mern-app ^
                        -Dsonar.sources=. ^
                        -Dsonar.host.url=http://localhost:9000 ^
                        -Dsonar.login=%SONAR_TOKEN%
                        """
                    }
                }
            }
        }
        

         stage('Docker Build Images') {
            steps {
                bat 'docker build -t %IMAGE_BACKEND% ./backend'
                bat 'docker build -t %IMAGE_FRONTEND% ./frontend'
            }
        }

        // 8. IMAGE SECURITY SCAN (AFTER BUILD)
        stage('Trivy Container Scan') {
            steps {
                bat "\"${TRIVY_PATH}\" image --severity HIGH,CRITICAL IMAGE_BACKEND"
                bat "\"${TRIVY_PATH}\" image --severity HIGH,CRITICAL IMAGE_FRONTEND"
            }
        }

         stage('Login to ECR') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'aws-creds', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
                    bat """
                    aws configure set aws_access_key_id %AWS_ACCESS_KEY_ID%
                    aws configure set aws_secret_access_key %AWS_SECRET_ACCESS_KEY%
                    aws configure set region %AWS_REGION%

                    aws ecr get-login-password --region %AWS_REGION% | docker login --username AWS --password-stdin %ECR_URL%
                    """
                }
            }
        }

        stage('Tag & Push to ECR') {
            steps {
                bat """
                docker tag %IMAGE_BACKEND%:latest %ECR_URL%/%IMAGE_BACKEND%:latest
                docker tag %IMAGE_FRONTEND%:latest %ECR_URL%/%IMAGE_FRONTEND%:latest

                docker push %ECR_URL%/%IMAGE_BACKEND%:latest
                docker push %ECR_URL%/%IMAGE_FRONTEND%:latest
                """
            }
        }

        stage('Deploy to EC2') {
            steps {
                bat """
                ssh -o StrictHostKeyChecking=no ubuntu@<EC2_IP> ^
                \"aws ecr get-login-password --region %AWS_REGION% | docker login --username AWS --password-stdin %ECR_URL% && ^
                docker compose pull && ^
                docker compose up -d\"
                """
            }
        }
    }
}